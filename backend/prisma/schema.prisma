// Prisma schema for backend (Postgres)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  PHOTOGRAPHER
  CLIENT
  EMPLOYEE
  SUPER_ADMIN
}

model User {
  id          Int         @id @default(autoincrement())
  email       String      @unique
  name        String?
  password    String?
  role        UserRole    @default(CLIENT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  photographer Photographer?
  orders      Order[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
}

model Photographer {
  id         Int       @id @default(autoincrement())
  user       User      @relation(fields: [userId], references: [id])
  userId     Int       @unique
  slug       String    @unique
  bio        String?
  galleries  Gallery[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Gallery {
  id          Int      @id @default(autoincrement())
  photographer Photographer @relation(fields: [photographerId], references: [id])
  photographerId Int
  title       String
  description String?
  photos      Photo[]
  createdAt   DateTime  @default(now())
}

model Photo {
  id           Int      @id @default(autoincrement())
  gallery      Gallery  @relation(fields: [galleryId], references: [id])
  galleryId    Int
  filename     String
  url          String
  width        Int?
  height       Int?
  size         Int?
  mimeType     String?
  watermarked  Boolean  @default(true)
  createdAt    DateTime @default(now())
  tags         String[]
}

model Order {
  id           Int       @id @default(autoincrement())
  client       User      @relation(fields: [clientId], references: [id])
  clientId     Int
  totalCents   Int
  currency     String    @default("BRL")
  status       String
  createdAt    DateTime  @default(now())
  payments     Payment[]
  items        OrderItem[]
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  order     Order  @relation(fields: [orderId], references: [id])
  orderId   Int
  photoId   Int
  priceCents Int
  quantity  Int    @default(1)
}

model Payment {
  id           Int      @id @default(autoincrement())
  order        Order    @relation(fields: [orderId], references: [id])
  orderId      Int
  provider     String
  providerId   String?
  amountCents  Int
  status       String
  method       String
  createdAt    DateTime @default(now())
}
